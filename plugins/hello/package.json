{
  "name": "@picoframe/plugin-hello",
  "version": "0.0.1",
  "description": "Example hello plugin for picoframe (frontend half): nav group, lazy routes, top-bar slot, typed IPC bindings",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tomjn/picoframe.git",
    "directory": "plugins/hello"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json"
  },
  "dependencies": {
    "lucide-react": "^1.16.0"
  },
  "peerDependencies": {
    "@picoframe/plugin-sdk": "*",
    "@tauri-apps/api": "^2.11.0",
    "react": "^19.0.0",
    "react-router": "^7.6.0"
  }
}
