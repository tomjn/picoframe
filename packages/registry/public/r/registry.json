{
  "$schema": "https://ui.shadcn.com/schema/registry.json",
  "name": "picoframe",
  "homepage": "https://github.com/tomjn/picoframe",
  "items": [
    {
      "name": "utils",
      "type": "registry:lib",
      "title": "cn util",
      "description": "Class-name merge helper (clsx + tailwind-merge) used by every picoframe primitive.",
      "dependencies": ["clsx", "tailwind-merge"],
      "files": [
        {
          "path": "registry/default/lib/utils.ts",
          "type": "registry:lib"
        }
      ]
    },
    {
      "name": "button",
      "type": "registry:ui",
      "title": "Button",
      "description": "Button with variants, sizes and asChild support.",
      "dependencies": ["radix-ui", "class-variance-authority"],
      "registryDependencies": ["utils"],
      "files": [
        {
          "path": "registry/default/ui/button.tsx",
          "type": "registry:ui"
        }
      ]
    },
    {
      "name": "dialog",
      "type": "registry:ui",
      "title": "Dialog",
      "description": "Modal dialog built on Radix Dialog.",
      "dependencies": ["radix-ui", "lucide-react"],
      "registryDependencies": ["utils", "button"],
      "files": [
        {
          "path": "registry/default/ui/dialog.tsx",
          "type": "registry:ui"
        }
      ]
    },
    {
      "name": "tooltip",
      "type": "registry:ui",
      "title": "Tooltip",
      "description": "Tooltip built on Radix Tooltip.",
      "dependencies": ["radix-ui"],
      "registryDependencies": ["utils"],
      "files": [
        {
          "path": "registry/default/ui/tooltip.tsx",
          "type": "registry:ui"
        }
      ]
    },
    {
      "name": "popover",
      "type": "registry:ui",
      "title": "Popover",
      "description": "Popover built on Radix Popover.",
      "dependencies": ["radix-ui"],
      "registryDependencies": ["utils"],
      "files": [
        {
          "path": "registry/default/ui/popover.tsx",
          "type": "registry:ui"
        }
      ]
    },
    {
      "name": "collapsible",
      "type": "registry:ui",
      "title": "Collapsible",
      "description": "Collapsible built on Radix Collapsible.",
      "dependencies": ["radix-ui"],
      "registryDependencies": ["utils"],
      "files": [
        {
          "path": "registry/default/ui/collapsible.tsx",
          "type": "registry:ui"
        }
      ]
    },
    {
      "name": "select",
      "type": "registry:ui",
      "title": "Select",
      "description": "Select built on Radix Select.",
      "dependencies": ["radix-ui", "lucide-react"],
      "registryDependencies": ["utils"],
      "files": [
        {
          "path": "registry/default/ui/select.tsx",
          "type": "registry:ui"
        }
      ]
    }
  ]
}
