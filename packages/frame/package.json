{
  "name": "@picoframe/frame",
  "version": "0.0.2",
  "description": "Reusable Tauri v2 app-frame React shell: sidebar, top bar, hash routing, nav and slot composition, theme",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tomjn/picoframe.git",
    "directory": "packages/frame"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./theme.css": "./src/theme.css"
  },
  "files": ["dist", "src/theme.css"],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json"
  },
  "dependencies": {
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "tailwind-merge": "^3.6.0",
    "lucide-react": "^1.16.0"
  },
  "peerDependencies": {
    "@picoframe/plugin-sdk": "*",
    "@tauri-apps/api": "^2.11.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router": "^7.6.0"
  }
}
